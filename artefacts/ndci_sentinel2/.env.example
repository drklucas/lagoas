# Copie este arquivo para .env e preencha os valores

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ndci
POSTGRES_USER=ndci
POSTGRES_PASSWORD=troque_esta_senha

# ── Google Earth Engine ───────────────────────────────────────────────────────
GEE_PROJECT=acontece-osorio

# Path para o JSON da service account GEE no seu sistema (Windows: use barras normais)
# O docker-compose monta este arquivo em /run/secrets/gee_key dentro do container
GEE_KEY_PATH=./credentials/gee-key.json

# ── Relatórios por e-mail (serviço scheduler) ─────────────────────────────────
# Servidor SMTP — exemplos:
#   Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   Office365/Outlook: SMTP_HOST=smtp.office365.com  SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_app_password_aqui
# Endereço remetente (deixe em branco para usar SMTP_USER)
SMTP_FROM=
# Use "true" apenas para porta 465 (SSL direto); 587 usa STARTTLS (padrão)
SMTP_USE_SSL=false

# Destinatários do boletim semanal — separados por vírgula
REPORT_RECIPIENTS=destinatario@exemplo.com,outro@exemplo.com

# Janela de busca de observações recentes em dias (padrão: 21)
# Sentinel-2 tem revisita ~5 dias; 21 dias cobre até 4 passagens
REPORT_LOOKBACK_DAYS=21

# ── Agendamento do scheduler (opcional — altere para ajustar horários) ────────
# Hora UTC da coleta diária de dados GEE (padrão: 06h UTC = 03h BRT)
COLLECT_HOUR_UTC=6
# Dia da semana do relatório: mon|tue|wed|thu|fri|sat|sun (padrão: mon)
REPORT_DAY_OF_WEEK=mon
# Hora UTC do envio do relatório semanal (padrão: 08h UTC = 05h BRT)
REPORT_HOUR_UTC=8
